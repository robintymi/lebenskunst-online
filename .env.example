# ============================================================
# Lebenskunst Online – Umgebungsvariablen
# Kopiere diese Datei als .env und fülle alle Werte aus.
# NIEMALS die echte .env in Git committen!
# ============================================================

# --- Datenbank ---
MONGODB_URI=mongodb://mongo:27017/lebenskunst

# --- Payload CMS ---
# Mindestens 32 zufällige Zeichen – z.B.: openssl rand -hex 32
PAYLOAD_SECRET=dein-sicherer-zufallsstring-mindestens-32-zeichen

# --- Server URL (kein abschließendes /) ---
NEXT_PUBLIC_SERVER_URL=https://lebenskunstonline.de

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook-Secret: nach Registrierung des Webhooks bei stripe.com eintragen
STRIPE_WEBHOOK_SECRET=whsec_...

# --- E-Mail (Resend) ---
RESEND_API_KEY=re_...
# Absender (Domain muss bei Resend verifiziert sein)
FROM_EMAIL=Lebenskunst <buchung@lebenskunstonline.de>
# Kontaktadresse in Kunden-E-Mails (z.B. Zahlungsfehlschlag-Benachrichtigung)
CONTACT_EMAIL=hallo@lebenskunstonline.de

# --- Rechnungen ---
# Nur setzen wenn Susanne NICHT Kleinunternehmerin (§ 19 UStG) ist.
# Wenn nicht gesetzt: Rechnungen zeigen "Gemäß § 19 UStG keine MwSt."
# INVOICE_SHOW_VAT=true
